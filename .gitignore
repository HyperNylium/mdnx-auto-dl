# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/
.env

# Ruff cache
.ruff_cache/

# OS junk
.DS_Store

# mdnx-auto-dl logs
appdata/logs/*
!appdata/logs/.gitkeep

# mdnx-auto-dl data
appdata/data/Anime/*
!appdata/data/Anime/.gitkeep
appdata/data/TV Shows/*
!appdata/data/TV Shows/.gitkeep

# multi-downloader-nx config
appdata/mdnx/config/*
!appdata/mdnx/config/.gitkeep

# multi-downloader-nx widevine CDM location
appdata/mdnx/widevine/*
!appdata/mdnx/widevine/.gitkeep

# multi-downloader-nx playready CDM location
appdata/mdnx/playready/*
!appdata/mdnx/playready/.gitkeep

# multi-downloader-nx linux CLI binary
appdata/mdnx/aniDL

# zlo config which includes GUI settings, service auth, default dubs/subs, etc.
appdata/zlo/config/*
!appdata/zlo/config/.gitkeep

# zlo binary
appdata/zlo/zlo7

# mdnx-auto-dl runtime SQLite queue
appdata/config/queue.db
appdata/config/queue.db-wal
appdata/config/queue.db-shm

# mdnx-auto-dl cached copy of the remote specials file
appdata/config/remote-specials-cache.yaml
appdata/config/remote-specials-cache.yaml.tmp

# my stuff
notes.txt
